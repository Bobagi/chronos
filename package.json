{
  "name": "chronos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nest start --watch",
    "dev:client": "vite dev --config client/vite.config.ts --host 0.0.0.0 --port ${CLIENT_PORT:-3055}",
    "build": "npm run build:server && npm run build:client",
    "build:server": "nest build",
    "build:client": "vite build --config client/vite.config.ts",
    "start": "concurrently -k \"npm:start:server\" \"npm:start:client\"",
    "start:server": "node server/dist/main.js",
    "start:client": "PORT=${CLIENT_PORT:-3055} node client/build",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:server": "eslint \"server/{src,test}/**/*.ts\"",
    "lint:client": "prettier --check client && eslint client",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.3",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pixi.js": "^8.10.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/browser": "^3.2.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.53.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "prisma": "^6.14.0",
    "source-map-support": "^0.5.21",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.2.6",
    "vitest": "^3.2.3",
    "vitest-browser-svelte": "^0.1.0"
  }
}
