{
  "name": "chronos-unified",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "svelte-kit sync || echo ''",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "sh -c \"tsc -p tsconfig.server.json && concurrently \\\"tsc -p tsconfig.server.json --watch\\\" \\\"node --watch dist/server/main.js\\\"\"",
    "dev:client": "vite dev --host 0.0.0.0 --port 3055",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "nest build --config tsconfig.server.build.json",
    "start": "node dist/server/main.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:server": "jest",
    "test:server:e2e": "jest --config ./server-test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio --port 5555 --hostname 0.0.0.0 --browser none"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.3",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pixi.js": "^8.10.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/browser": "^3.2.3",
    "concurrently": "^8.2.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.53.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "prisma": "^6.14.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.2.6",
    "vitest": "^3.2.3",
    "vitest-browser-svelte": "^0.1.0"
  }
}
